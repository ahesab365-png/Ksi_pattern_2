{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/article/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/category/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/upload/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/user/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1",
      "check": true
    }
  ]
}
